# Only needed to (re)generate the semantic-search embedding index via Workers AI.
# The stdio server runs fine without these (keyword search fallback).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Embedding model used for the knowledge base (Cloudflare Workers AI).
XTOOL_EMBEDDING_MODEL=@cf/baai/bge-large-en-v1.5
